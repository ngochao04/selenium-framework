<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Lab9Suite" parallel="methods" thread-count="3" verbose="2">

  <listeners>
    <listener class-name="framework.utils.RetryListener"/>
  </listeners>

  <parameter name="browser" value="chrome"/>
  <parameter name="env" value="dev"/>

  <test name="LoginTests">
    <classes>
      <class name="tests.LoginTest"/>
      <class name="tests.LoginDDTTest"/>
    </classes>
  </test>

  <test name="FlakyTests">
    <classes>
      <class name="tests.FlakySimulationTest"/>
    </classes>
  </test>

</suite>